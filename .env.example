# Copy this file to ".env" and fill in the keys you need.
# The pipeline auto-loads ".env" from the project directory.
# Do NOT commit your real .env file (.gitignore already excludes it).

# Recommended: one key covers open-source + mid-tier models.
# Get it at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Only needed if you use --provider anthropic / openai.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Other open-source model hosts (optional).
TOGETHER_API_KEY=
GROQ_API_KEY=
DEEPINFRA_API_KEY=

# OpenReview login is OPTIONAL — public papers/decisions are readable
# anonymously, so the fetch step works without these.
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=
